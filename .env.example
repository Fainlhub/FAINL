# Public browser configuration (safe to expose in a Vite bundle).
# Must match the deployed origin used in Supabase Auth redirect URLs.
# Production example: VITE_SITE_URL=https://www.fainl.com
# Do not set this to your Supabase project URL.
VITE_SITE_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key

# Server-only values belong in Supabase Edge Function secrets, not VITE_* vars:
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# HF_TOKEN=
# IMAGE_COUNCIL_FIXTURE_MODE=false
# IMAGE_COUNCIL_WORKER_TOKEN=
# IMAGE_COUNCIL_ENABLED=false
# IMAGE_COUNCIL_GEMINI_GENERATOR_MODEL=gemini-3.1-flash-image
# IMAGE_COUNCIL_GEMINI_EDITOR_MODEL=gemini-3-pro-image
# IMAGE_COUNCIL_OPENAI_MODEL=gpt-image-2
# IMAGE_COUNCIL_HF_QWEN_MODEL=Qwen/Qwen-Image
# IMAGE_COUNCIL_HF_ZIMAGE_MODEL=Tongyi-MAI/Z-Image-Turbo
# IMAGE_COUNCIL_HF_SDXL_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# NEWS_ADMIN_TOKEN=
# NEWS_TEXT_MODEL=gpt-4.1-mini
# NEWS_IMAGE_MODEL=gpt-image-1
# NEWS_AUTO_PUBLISH=false
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
# PERPLEXITY_API_KEY=
# NEMOTRON_API_KEY=
# GLM_API_KEY=
