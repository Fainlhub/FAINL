# Public browser configuration (safe to expose in a Vite bundle).
# Must match the deployed origin used in Supabase Auth redirect URLs.
VITE_SITE_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key

# Server-only values belong in Supabase Edge Function secrets, not VITE_* vars:
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
# PERPLEXITY_API_KEY=
# NEMOTRON_API_KEY=
# GLM_API_KEY=
